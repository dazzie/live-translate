# Python AI service config — copy to `.env`

# Choose the provider (see lib/llm.py): "anthropic" (default) or "openrouter"
LLM_PROVIDER=anthropic

# Set the key for the provider you choose. Only the active one is required.
ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...   # route through OpenRouter to keep the provider swappable
# GEMINI_API_KEY=...

# MODEL must be a slug the chosen provider understands:
#   anthropic  → claude-sonnet-4-6
#   openrouter → openai/gpt-4o-mini, anthropic/claude-3.5-sonnet, meta-llama/llama-3.1-8b-instruct, …
MODEL=claude-sonnet-4-6

TRANSLATION_DB_PATH=translations.db
